# 强制 Linux 部署相关文件使用 LF 行尾，
# 避免在 Windows 上 clone/编辑后引入 CRLF 导致 bash/systemd 解析失败。
*.sh         text eol=lf
*.py         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.conf       text eol=lf
*.service    text eol=lf
*.md         text eol=lf
.env.example text eol=lf
.gitignore   text eol=lf
deploy.sh    text eol=lf

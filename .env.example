# Isolated xui deployment
XUI_DEPLOY_DIR=/opt/xui
ENABLE_XUI=true
XUI_VERSION=v3.0.2
XUI_ADMIN_USERNAME=CHANGE_ME_XUI_ADMIN
XUI_ADMIN_PASSWORD=CHANGE_ME_XUI_PASSWORD
XUI_PANEL_PORT=12053
XUI_REALITY_PORT=31444
# 面板隐藏路径（防扫描爆破）。默认 / ；设成不易猜的路径（如 /a8f3k2/，前后带斜杠）更安全。
# deploy.sh xui 会按此值设置 webBasePath（脚本不再写死为 /），重跑可复现而非覆盖。
XUI_WEB_BASE_PATH=/
# 固定 xui docker 网络网段，保证网关 IP（默认 172.19.0.1）稳定 —— 当 privoxy 绑定该网关
# 地址供容器访问时很重要（避免网络重建后网段漂移）。
XUI_NETWORK_SUBNET=172.19.0.0/16

# 可选：xui 自带 Cloudflare 隧道（通过域名访问面板，独立于其他项目的隧道）。
# 在 Cloudflare 后台新建隧道（如 hk1-xui），复制其 token 填入下方；
# 启用：docker compose --profile tunnel up -d
# 后台为该隧道添加路由：xui.<你的域名> -> http://xui-3xui:12053
XUI_TUNNEL_TOKEN=

# Optional NAT egress proxy for hosts that need a local HTTP proxy.
ENABLE_NAT_PROXY=false
NAT_SSH_HOST=
# NAT 网关常把内部 22 映射到一个高位公网端口，填服务商给出的 SSH 端口。
NAT_SSH_PORT=22
NAT_SSH_USER=root
NAT_SSH_KEY_PATH=/root/.ssh/nat_ed25519
NAT_SOCKS_LISTEN=127.0.0.1:10808
# privoxy 本地 HTTP 代理监听地址，空格分隔可填多个（各生成一条 listen-address）。
#   仅本机用（默认，最简单）：           127.0.0.1:7890
#   让本机 docker 容器也用且不暴露公网（纵深防御，推荐）：
#       NAT_HTTP_LISTEN="127.0.0.1:7890 172.19.0.1:7890"   # 后者为 xui_default 网关
#   不建议 0.0.0.0：会监听公网网卡，安全只剩防火墙单点。
NAT_HTTP_LISTEN=127.0.0.1:7890
# 为非回环监听地址放行的来源网段（让容器能访问；公网因属私有地址本就到不了）。
# 用内网网关绑定时设为对应 docker 网段，例：172.19.0.0/16。留空则不加 ufw 规则。
NAT_HTTP_ALLOW_CIDR=
